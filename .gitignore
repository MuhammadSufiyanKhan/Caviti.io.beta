# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Environment variables (CRITICAL - never commit secrets)
.env
.env.local
.env.*.local
.env.production
# But DO commit example/template files
!.env.example
!.env.production.example

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel
*.log

# Debug scripts & test files
DEBUG_RUN.md
verify-*.js
**/test.txt
**/debug*.txt
**/patch.txt
.debug/

# IDE
.vscode/
.idea/
*.swp
*.swo
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
