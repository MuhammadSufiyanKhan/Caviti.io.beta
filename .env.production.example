# Production Environment Template

## ⚠️ WARNING: Do NOT Commit This File
Copy this to `.env.production.local` and fill in your production values.
NEVER commit `.env.production.local` to Git.

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-production-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key_here

# ============================================
# SITE CONFIG
# ============================================
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ============================================
# ADMIN CONFIG
# ============================================
ADMIN_EMAILS=admin@yourdomain.com,support@yourdomain.com

# ============================================
# AI SERVICES
# ============================================
GROQ_API_KEY=your_production_groq_key_here
OPENAI_API_KEY=your_production_openai_key_here
FIRECRAWL_API_KEY=your_production_firecrawl_key_here

# ============================================
# DATA & SCRAPING
# ============================================
APIFY_API_KEY=your_production_apify_key_here
SERPAPI_KEY=your_production_serpapi_key_here

# ============================================
# EMAIL SERVICE
# ============================================
RESEND_API_KEY=your_production_resend_key_here

# ============================================
# OPTIONAL: MONITORING & ANALYTICS
# ============================================
# SENTRY_DSN=your_sentry_dsn_here
# DATADOG_API_KEY=your_datadog_key_here
